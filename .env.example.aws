# Artemis AWS Build — Environment Variables
#
# SECRETS POLICY: All credentials come from AWS Secrets Manager.
# Only these 5 env vars are needed. No passwords, tokens, or API keys here.

RDS_SECRET_ARN=            # ARN of the RDS secret in Secrets Manager
RDS_HOST=                  # RDS endpoint hostname (e.g. rdmis-dev.xxxx.us-east-1.rds.amazonaws.com)
RDS_DB=crm                 # Database name (default: crm)
AWS_REGION=us-east-1       # AWS region
ENVIRONMENT=dev            # dev / prod
